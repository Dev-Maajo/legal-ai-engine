# ── NVIDIA NIM (required for AI chat and summarization) ─────────────────────────
# Get a free API key at https://build.nvidia.com
NVIDIA_API_KEY=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

# Model for main responses — any chat model available on build.nvidia.com works.
# Recommended options:
#   meta/llama-3.1-70b-instruct   (best quality, default)
#   meta/llama-3.3-70b-instruct   (latest Llama 3.3)
#   meta/llama-3.1-8b-instruct    (faster, lower cost)
#   nvidia/llama-3.1-nemotron-70b-instruct  (NVIDIA-optimised)
#   meta/llama-3.1-70b-instruct
NVIDIA_MODEL=meta/llama-3.1-70b-instruct

# Smaller model used only for query expansion (2 sub-queries per request).
# Defaults to the 8B variant to save tokens on this lightweight task.
NVIDIA_FAST_MODEL=meta/llama-3.1-8b-instruct

# Base URL — do not change unless you are running a self-hosted NIM instance.
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# ── App ──────────────────────────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change-me-to-a-long-random-string-in-production

# Origins allowed by CORS — JSON array format required.
# Add your production frontend URL here.
ALLOWED_ORIGINS=["https://legalai.hayatech.dev","http://localhost:3000","http://127.0.0.1:3000"]

# ── Storage ──────────────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
CHROMA_DB_PATH=./chroma_db
MAX_FILE_SIZE_MB=50

# ── Embeddings (local sentence-transformers model — no API key needed) ───────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ── Retrieval ────────────────────────────────────────────────────────────────────
RETRIEVAL_TOP_K=10
RETRIEVAL_SCORE_THRESHOLD=0.25
MAX_CONTEXT_CHARS=16000
MULTI_QUERY_ENABLED=true

# ── Supabase (only required when running backend/app/main.py — not needed for  ──
# ── the standalone backend/main.py dev server) ───────────────────────────────────
# SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
# SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# SUPABASE_JWT_SECRET=your-jwt-secret-here
